# ==========================================
# Mobatech AI Orchestrator Configuration
# ==========================================
# WARNING: Do not put actual secrets in this file!
# Copy this file to .env and replace placeholders with real values.

# ------------------------------------------
# Server Configuration
# ------------------------------------------
API_TITLE="Hermina AI Orchestrator"
API_HOST=0.0.0.0
# The port on which the Python FastAPI server will run.
API_PORT=8000

# ------------------------------------------
# Database Configuration (MySQL)
# ------------------------------------------
# Must match the credentials used by the Backend for cross-service sync.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
# Replace with your actual MySQL password
DB_PASSWORD=your_secure_database_password
DB_NAME=mobatech
