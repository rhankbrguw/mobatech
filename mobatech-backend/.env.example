# ==========================================
# Mobatech Backend Configuration
# ==========================================
# WARNING: Do not put actual secrets in this file!
# Copy this file to .env and replace placeholders with real values.

# ------------------------------------------
# Server Configuration
# ------------------------------------------
# The port on which the Go backend server will run.
PORT=8080

# ------------------------------------------
# Database Configuration (MySQL)
# ------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
# Replace with your actual MySQL password
DB_PASSWORD=your_secure_database_password
DB_NAME=mobatech

# ------------------------------------------
# Security & Authentication
# ------------------------------------------
# Used for signing JSON Web Tokens. Generate a strong random string (min 32 chars).
JWT_SECRET=generate_a_secure_random_string_for_jwt

# ------------------------------------------
# Third-Party API Integrations
# ------------------------------------------
# Google Gemini API key for AI features. Obtain from Google AI Studio.
GEMINI_API_KEY=your_gemini_api_key_here
