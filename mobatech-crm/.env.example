# ==========================================
# Mobatech CRM Portal Configuration
# ==========================================
# WARNING: Do not put actual secrets in this file!
# Copy this file to .env.local and replace placeholders with real values.

# ------------------------------------------
# API Connections
# ------------------------------------------
# Base URL pointing to the Mobatech Go Backend API.
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# ------------------------------------------
# Security & Encryption
# ------------------------------------------
# Symmetric key used for encrypting/decrypting sensitive patient payload data (AES-256).
# Must be exactly 32 characters long.
NEXT_PUBLIC_ENCRYPTION_KEY=your_32_character_encryption_key
