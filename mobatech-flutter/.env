# Base API URL for backend
# For Android emulator use: http://10.0.2.2:8080/api
# For physical devices on the same Wi-Fi use your PC's IP, e.g.: http://192.168.1.100:8080/api
# For production use: https://api.mobatech.com/api
API_BASE_URL=http://10.0.2.2:8080/api

# WebSocket URL for live tracking
# For Android emulator use: ws://10.0.2.2:8080/api
# For physical devices use your PC's IP, e.g.: ws://192.168.1.100:8080/api
# For production use: wss://api.mobatech.com/api
WS_BASE_URL=ws://10.0.2.2:8080/api
