# Base API URL for backend
# For Android emulator use: http://10.0.2.2:8080/api
# For physical devices use: http://<YOUR_IP>:8080/api
API_BASE_URL=http://10.0.2.2:8080/api

# WebSocket URL for live tracking
# For Android emulator use: ws://10.0.2.2:8080/api
# For physical devices use: ws://<YOUR_IP>:8080/api
WS_BASE_URL=ws://10.0.2.2:8080/api
